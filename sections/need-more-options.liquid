{% liquid
  assign slide_count = section.blocks.size
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} need-more-options spacing-style"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --need-more-options-section-bg: {{ section.settings.section_background }};
    --need-more-options-heading-color: {{ section.settings.heading_color }};
    --need-more-options-card-gap: {{ section.settings.card_gap }}px;
    --need-more-options-card-radius: {{ section.settings.card_radius }}px;
  "
  data-testid="need-more-options-{{ section.id }}"
>
  {% if section.settings.heading != blank %}
    <h2 class="need-more-options__heading">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  {% if slide_count > 0 %}
    <div class="need-more-options__grid hidden--mobile">
      {% for block in section.blocks %}
        {% render 'need-more-options-card', block: block %}
      {% endfor %}
    </div>

    {% if slide_count > 1 %}
      {% capture controls %}
        {%- render 'slideshow-controls',
          style: 'dots',
          item_count: slide_count,
          show_arrows: false,
          pagination_position: 'center'
        -%}
      {% endcapture %}

      {% capture slides %}
        {% for block in section.blocks %}
          {% capture slide_children %}
            {% render 'need-more-options-card', block: block %}
          {% endcapture %}
          {% render 'slideshow-slide',
            index: forloop.index0,
            children: slide_children,
            class: 'need-more-options__slide'
          %}
        {% endfor %}
      {% endcapture %}

      {% assign need_more_options_ref = 'needMoreOptions' | append: section.id %}

      <div class="need-more-options__carousel hidden--desktop">
        {% render 'slideshow',
          ref: need_more_options_ref,
          class: 'need-more-options__slideshow',
          slides: slides,
          slide_count: slide_count,
          controls: controls,
          show_arrows: false,
          infinite: false,
          initial_slide: 0
        %}
      </div>
    {% else %}
      <div class="need-more-options__grid hidden--desktop">
        {% render 'need-more-options-card', block: section.blocks.first %}
      </div>
    {% endif %}
  {% endif %}
</div>

{% stylesheet %}
  .need-more-options {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background-color: var(--need-more-options-section-bg, #ffffff);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding-inline: clamp(0.25rem, 1vw, 0.5rem);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .need-more-options__heading {
    width: 100%;
    max-width: 80rem;
    margin-inline: auto;
    margin-block: 0;
    text-align: left;
    font-size: clamp(1.15rem, 3.83vw, 3rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--need-more-options-heading-color, #9ba3af);
    line-height: 1.2;
  }

  .need-more-options__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 60%));
    gap: var(--need-more-options-card-gap, 1.5rem);
    width: 100%;
    max-width: 80rem; /* change this to change card size */
    margin-inline: auto;
  }

  .need-more-options__card {
    container-type: inline-size;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0rem;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 2.5vw, 2rem);
    border-radius: var(--need-more-options-card-radius, 1.5rem);
    background-color: var(--need-more-options-card-bg, #fef2e9);
    min-height: 100%;
  }

  .need-more-options__card-heading {
    align-self: stretch;
    width: 100%;
    max-width: 100%;
    margin: 0;
    font-size: clamp(1.15rem, 3.83vw, 3rem);
    font-weight: 800;
    letter-spacing: 0.01em;
    line-height: 1.25;
    min-height: calc(3 * 1.25em);
    max-height: calc(3 * 1.25em);
    text-transform: uppercase;
    text-align: center;
    text-justify: inter-word;
    hyphens: none;
    color: var(--need-more-options-accent);
    overflow: hidden;
  }

  .need-more-options__card-media {
    width: 100%;
    /* max-width: 20rem; */
    /* margin-inline: auto; */
    margin-inline: calc(-1 * clamp(1.25rem, 2.5vw, 2rem));
  }

  .need-more-options__card-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .need-more-options__card-actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.75rem;
    margin-top: auto;
    width: 100%;
    align-self: stretch;
  }

  .need-more-options__button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin-top: 1.25rem;
    min-height: 3rem;
    padding: 0.75rem 1.75rem;
    border: 1px solid #000000;
    border-radius: 9999px;
    background-color: transparent;
    color: #000000;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.3;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    text-align: center;
    box-sizing: border-box;
  }

  .need-more-options__button:hover {
    background-color: #000000;
    color: var(--hover-accent) !important;
  }

  .need-more-options__button[aria-disabled='true'] {
    opacity: 1;
    pointer-events: none;
  }

  .need-more-options__disclaimer {
    margin: 0;
    font-size: 0.925rem;
    font-weight: 600;
    font-style: italic;
    line-height: 1.4;
    color: #111111;
  }

  .need-more-options__carousel {
    width: 100% !important;  
    margin-inline: auto;
    overflow: hidden;
  }

  .need-more-options__slideshow {
    --slide-width: min(90vw, 50rem);
    position: relative;
  }

  .need-more-options__slideshow slideshow-slides {
    gap: var(--need-more-options-card-gap);
    padding-inline: max(1rem, calc((100% - var(--slide-width)) / 2));
    scroll-padding-inline: max(1rem, calc((100% - var(--slide-width)) / 2));
  }

  .need-more-options__slide {
    width: 100% !important;
    flex: 0 0 auto;
    scroll-snap-align: center;
    min-width: 0;
  }

  .need-more-options__slideshow .slideshow-controls {
    margin-top: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
  }

.need-more-options__slideshow .slideshow-control.button[aria-selected="true"] {
  --color: #E4772E !important;
}

  @media screen and (max-width: 749px) {
    .need-more-options:has(.need-more-options__carousel) {
      --need-more-options-slide-width: min(90vw, 100%);
      --need-more-options-carousel-gutter: max(1rem, calc((100% - var(--need-more-options-slide-width)) / 2));
    }

    .need-more-options:has(.need-more-options__carousel) .need-more-options__heading {
      width: 92%;
      margin-inline: auto;
      max-width: none;
      font-size: clamp(1.25rem, 3vw, 2.25rem);
      padding-inline-start: var(--need-more-options-carousel-gutter);
      padding-inline-end: 1rem;
      box-sizing: border-box;
    }

    .need-more-options {
      padding-inline: clamp(0.5rem, 4vw, 1rem);
      width: 100%;
    }

    .need-more-options:has(.need-more-options__carousel) .need-more-options__slideshow {
      --slide-width: var(--need-more-options-slide-width);
    }

    .need-more-options:has(.need-more-options__carousel) .need-more-options__slideshow slideshow-slides {
      padding-inline: var(--need-more-options-carousel-gutter)
        max(1rem, calc((100% - var(--need-more-options-slide-width)) / 2));
      scroll-padding-inline: var(--need-more-options-carousel-gutter)
        max(1rem, calc((100% - var(--need-more-options-slide-width)) / 2));
    }

    .need-more-options__grid {
      grid-template-columns: 1fr;
    }

    .need-more-options__card-heading {
      font-size: clamp(1.25rem, 3.83vw, 2rem);
      min-height: calc(3 * 1.25em);
      max-height: calc(3 * 1.25em);
      text-align: right;
      text-align-last: right;
      text-justify: auto;
    }

    .need-more-options__button {
      font-size: 0.825rem;
      min-height: 2.75rem;
      padding: 0.625rem 1.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Need more options",
  "tag": "section",
  "class": "need-more-options-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NEED MORE OPTIONS?"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#9BA3AF"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Option card",
      "settings": [
        {
          "type": "select",
          "id": "theme",
          "label": "Theme",
          "options": [
            {
              "value": "vinyl",
              "label": "Vinyl (orange)"
            },
            {
              "value": "wood",
              "label": "Wood (blue)"
            }
          ],
          "default": "vinyl"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Card heading",
          "default": "THE ONLY CUSTOM VINYL SWINGSETS IN CHICAGOLAND."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Illustration"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label (desktop)",
          "default": "Go to 3D Vinyl Design Center"
        },
        {
          "type": "text",
          "id": "button_label_mobile",
          "label": "Button label (mobile)",
          "default": "Share link to Vinyl Design Center"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "text",
          "id": "disclaimer",
          "label": "Disclaimer",
          "default": "This tool is only available on desktop devices."
        },
        {
          "type": "header",
          "content": "Advanced colors"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Accent color"
        },
        {
          "type": "color",
          "id": "card_background",
          "label": "Card background"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Need more options",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "theme": "vinyl",
            "heading": "THE ONLY CUSTOM VINYL SWINGSETS IN CHICAGOLAND.",
            "button_label": "Go to 3D Vinyl Design Center",
            "button_label_mobile": "Share link to Vinyl Design Center",
            "disclaimer": "This tool is only available on desktop devices."
          }
        },
        {
          "type": "card",
          "settings": {
            "theme": "wood",
            "heading": "THE BEST CUSTOM WOOD PLAYSETS IN CHICAGOLAND.",
            "button_label": "Go to 3D Wood Design Center",
            "button_label_mobile": "Share Link to Wood Design Center",
            "disclaimer": "This tool is only available on desktop devices."
          }
        }
      ]
    }
  ]
}
{% endschema %}
